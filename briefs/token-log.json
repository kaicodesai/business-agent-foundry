    "tokens_input": "prompt tokens used",
    "tokens_output": "completion tokens used",
    "model": "Claude model used",
    "cost_usd": "actual Anthropic API cost (tokens × rate)",
    "time_saved_minutes": "estimated minutes a human would take for the same task",
    "hourly_rate_usd": "assumed human hourly rate for comparison (default 50)",
